# --- Preflight helpers for CLT/Swift availability ---
def _swift_available() -> bool:
    """Return True if Swift is available on this system."""
    try:
        return subprocess.run(['/usr/bin/swift', '--version'], capture_output=True).returncode == 0
    except Exception:
        return False

def _clt_installed() -> bool:
    """Return True if Apple Command Line Tools are installed."""
    try:
        return subprocess.run(['/usr/bin/xcode-select', '-p'], capture_output=True).returncode == 0
    except Exception:
        return False

# --- Headless CLT install attempt (falls back to GUI if it fails) ---

def _parse_clt_label(sw_out: str) -> str:
    """Extract a suitable 'Command Line Tools' label from softwareupdate -l output."""
    label = None
    for raw in (sw_out or '').splitlines():
        line = raw.strip()
        if 'Label:' in line and 'Command Line Tools' in line:
            # Expected format: "* Label: Command Line Tools for Xcode-15.3"
            try:
                label = line.split('Label:')[1].strip()
            except Exception:
                continue
    return label or ''


def _install_clt_headless(max_wait_sec: int = 900) -> bool:
    """
    Try to install Apple Command Line Tools non-interactively using softwareupdate.
    Returns True if Swift becomes available within max_wait_sec; False otherwise.
    """
    try:
        # Make CLT visible to softwareupdate and query label
        subprocess.run(['/usr/bin/touch', '/tmp/.com.apple.dt.CommandLineTools.installondemand.in-progress'], check=False)
        proc = subprocess.run(['/usr/sbin/softwareupdate', '-l'], capture_output=True, text=True)
        label = _parse_clt_label(proc.stdout if proc.returncode == 0 else '')
        if not label:
            print('ℹ️  No "Command Line Tools" label found via softwareupdate; headless install not available on this OS.')
            return False
        print(f'⬇️  Attempting headless install of: {label}')
        # Install the specific label; this may require admin authorization
        inst = subprocess.run(['/usr/sbin/softwareupdate', '-i', label], text=True)
        if inst.returncode != 0:
            print(f'⚠️  softwareupdate returned {inst.returncode}; headless install likely failed.')
            return False
        # Poll for Swift availability
        start = time.time()
        while time.time() - start < max_wait_sec:
            if _swift_available():
                print('✅ Command Line Tools installed (Swift found).')
                return True
            time.sleep(5)
        print('⚠️  Headless install timed out waiting for Swift to appear.')
        return _swift_available()
    finally:
        subprocess.run(['/bin/rm', '-f', '/tmp/.com.apple.dt.CommandLineTools.installondemand.in-progress'], check=False)

